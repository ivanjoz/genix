{
	"name": "genix-frontend",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"workspaces": [
		"./ecommerce"
	],
	"scripts": {
		"dev": "bun scripts/dev-all.js",
		"dev:main": "vite dev --force --port 3570",
		"dev:store": "cd ecommerce && bun run dev",
		"serve": "bun run serve:build",
		"serve:build": "bun x serve ./build -l 3000",
		"prepare": "svelte-kit sync || echo ''",
		"build": "bun scripts/build-all.js",
		"build:main": "vite build",
		"build:store": "cd ecommerce && bun run build",
		"publish": "bun run build && bun postbuild.js --publish",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"prebuild:store": "bun scripts/thumbhash-prebuild.js"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.18",
		"@tailwindcss/vite": "^4.1.13",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^24.10.0",
		"http-proxy": "^1.18.1",
		"http-proxy-middleware": "^3.0.5",
		"sharp": "^0.34.3",
		"svelte": "^5.46.0",
		"svelte-check": "^4.3.2",
		"svelte-infinitable": "^0.0.14",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "^8.0.0"
	},
	"dependencies": {
		"@humanspeak/svelte-virtual-list": "^0.3.5",
		"@jsquash/avif": "^2.1.1",
		"@observablehq/plot": "^0.6.17",
		"axios": "^1.13.2",
		"billboard.js": "^3.14.3",
		"date-fns": "^4.1.0",
		"dexie": "^4.2.0",
		"embla-carousel-svelte": "^8.6.0",
		"esbuild": "^0.25.12",
		"excelize-wasm": "^0.1.1",
		"layerchart": "^1.0.13",
		"leafer-ui": "^2.0.3",
		"mime-types": "^3.0.1",
		"notiflix": "^3.2.8",
		"peerjs": "^1.5.5",
		"roosterjs": "^9.41.0",
		"svelte-awesome-color-picker": "^4.1.0",
		"svelte-lexical": "^0.6.3",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"thumbhash": "^0.1.1",
		"yaml": "^2.8.2"
	}
}
