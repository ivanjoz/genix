{
	"project_name": "genix",
	"file_scan_exclusions": [
		"**/frontend_deprecated/**",
		"**/node_modules/**",
		"**/dist/**",
		"**/build/**",
		"**/target/**",
		"**/.git/**",
		"**/ai/**",
		"**/.vscode/**",
		"./docs/**",
		"**/store_deprecated/**",
		"**/.svelte-kit/**",
	],
	"languages": {
		"TypeScript": {
			"language_servers": [
				"vtsls",
				"!tailwindcss-language-server"
			]
		},
		"TSX": {
			"language_servers": [
				"vtsls",
				"!tailwindcss-language-server"
			]
		},
		"Svelte": {
			"language_servers": [
				"svelte-language-server",
				"!tailwindcss-language-server"
			]
		},
		"HTML": {
			"language_servers": [
				"!tailwindcss-language-server"
			]
		},
		"CSS": {
			"language_servers": [
				"!tailwindcss-language-server"
			]
		}
	},
	"lsp": {
		"vtsls": {
			"settings": {
				"typescript": {
					"tsserver": {
						"maxTsServerMemory": 3072,
						"useSeparateSyntaxServer": false
					}
				}
			}
		}
	}
}
